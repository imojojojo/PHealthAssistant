# ── LLM Provider (default: Gemini) ───────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
LLM_CHAT_MODEL=gemini-2.5-flash
LLM_EMBEDDING_MODEL=gemini-embedding-001

# ── Vector Store (default: ChromaDB) ─────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=patient-records

# ── Application ───────────────────────────────────────────────────────────────
# Path to the folder containing patient JSON files (relative to project root)
DATA_DIR=data/patients
